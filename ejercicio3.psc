Algoritmo ejercicio3
	Definir letra Como Caracter
	Escribir Sin Saltar "digite una letra"
	leer letra
	
	Segun letra Hacer
		"A" o "a":
		Escribir "exelente"
	"B" o "b":
		Escribir "Bueno"
	"C" o "c":
		Escribir "regular"
	"D" o "d":
		Escribir "DEFICIENTE"
	"F" o "f":
		Escribir "reprobado"
		
		De Otro Modo:
			Escribir "LETRA NO VALIDA"
	Fin Segun
FinAlgoritmo
